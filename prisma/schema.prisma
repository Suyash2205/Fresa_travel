// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  AGENT
}

enum StatementState {
  DRAFT
  APPROVED
  PAID
}

enum ReferralStatus {
  NOT_ORDERED
  ORDERED
  COMMISSION_APPROVED
  PAID
  CANCELLED
}

enum MatchMethod {
  EMAIL
  PHONE
  BOTH
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(AGENT)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  agent         Agent?
  importBatches TravellerImportBatch[] @relation("BatchCreatedBy")
  auditLogs     AuditLog[] @relation("AuditActor")
}

model Agent {
  id                 String   @id @default(cuid())
  userId             String   @unique
  code               String   @unique
  companyName        String?
  contactName        String?
  payoutMetadataJson String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  travellers         Traveller[]
  orderReferrals     OrderReferral[]
  statements         MonthlyCommissionStatement[]
}

model TravellerImportBatch {
  id            String   @id @default(cuid())
  createdById   String
  fileName      String
  totalRows     Int      @default(0)
  insertedRows  Int      @default(0)
  conflictedRows Int     @default(0)
  createdAt     DateTime @default(now())
  createdBy     User     @relation("BatchCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  travellers    Traveller[]
}

model Traveller {
  id           String   @id @default(cuid())
  batchId      String
  agentId      String
  name         String?
  email        String?
  phone        String?
  normalizedEmail String?
  normalizedPhone String?
  firstSeenAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  batch        TravellerImportBatch @relation(fields: [batchId], references: [id], onDelete: Restrict)
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Restrict)
  referrals    OrderReferral[]

  @@index([normalizedEmail])
  @@index([normalizedPhone])
}

model Order {
  id               String   @id @default(cuid())
  shopifyOrderId   String   @unique
  orderNumber      String?
  customerEmail    String?
  customerPhone    String?
  normalizedEmail  String?
  normalizedPhone  String?
  subtotalAmount   Decimal  @db.Decimal(12, 2)
  currency         String   @default("INR")
  financialStatus  String
  createdAtShopify DateTime
  updatedAtShopify DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  referral         OrderReferral?

  @@index([normalizedEmail])
  @@index([normalizedPhone])
}

model OrderReferral {
  id               String   @id @default(cuid())
  orderId          String   @unique
  travellerId      String
  agentId          String
  statementItem    StatementItem?
  matchMethod      MatchMethod
  commissionBase   Decimal  @db.Decimal(12, 2)
  commissionAmount Decimal  @db.Decimal(12, 2)
  status           ReferralStatus @default(ORDERED)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  traveller        Traveller @relation(fields: [travellerId], references: [id], onDelete: Restrict)
  agent            Agent    @relation(fields: [agentId], references: [id], onDelete: Restrict)
}

model MonthlyCommissionStatement {
  id              String   @id @default(cuid())
  agentId         String
  month           DateTime
  totalCommission Decimal  @db.Decimal(12, 2)
  state           StatementState @default(DRAFT)
  approvedAt      DateTime?
  approvedById    String?
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  items           StatementItem[]
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Restrict)

  @@unique([agentId, month])
}

model StatementItem {
  id              String   @id @default(cuid())
  statementId     String
  orderReferralId String   @unique
  amountSnapshot  Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  statement       MonthlyCommissionStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  orderReferral   OrderReferral @relation(fields: [orderReferralId], references: [id], onDelete: Restrict)
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  payloadJson String?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
